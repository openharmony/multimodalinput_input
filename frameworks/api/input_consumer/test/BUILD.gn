import("../../../../multimodalinput_mini.gni")

config("input_consumer_test_config") {
  visibility = [ ":*" ]
  include_dirs = [
    "${mmi_path}/frameworks/api/input_consumer/include",
    "${mmi_path}/frameworks/proxy/include",
    "${mmi_path}/interfaces/native/innerkits/include",
    "${mmi_path}/util/common/include",
    "${mmi_path}/service/common/include",
    "../../../third_party/gtest/include",
  ]
}

ohos_unittest("js_register_module_test") {
  module_out_path = "${module_rel_path}/input_consumer/test"

  sources = [
    "js_register_module_test.cpp",
  ]

  configs = [
    "${mmi_path}:coverage_flags",
    ":input_consumer_test_config",
  ]

  deps = [
    "${mmi_path}/frameworks/api/input_consumer:inputconsumer",
    "${mmi_path}/frameworks/proxy:libmmi-client",
    "${mmi_path}/util:libmmi-util",
  ]

  external_deps = [
    "c_utils:utils",
    "hilog:libhilog",
    "googletest:gmock_main",
    "googletest:gtest_main",
  ]
}
