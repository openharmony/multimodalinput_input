import("//build/ohos.gni")
import("//foundation/multimodalinput/input/multimodalinput_mini.gni")

template("mmi_systemtest_executable") {
  ohos_executable(target_name) {
    forward_variables_from(invoker, "*")

    if (!defined(include_dirs)) {
      include_dirs = []
    }
    include_dirs += [
      "${mmi_path}/interfaces/native/innerkits/proxy/include",
      "${mmi_path}/interfaces/native/innerkits/event/include",
    ]

    if (!defined(deps)) {
      deps = []
    }
    deps += [
      "${mmi_path}/frameworks/proxy:libmmi-client",
      "${mmi_path}/util:libmmi-util",
    ]

    if (!defined(external_deps)) {
      external_deps = []
    }
    external_deps += [
      "c_utils:utils",
      "eventhandler:libeventhandler",
      "hilog:libhilog",
      "ipc:ipc_single",
    ]

    sanitize = {
      cfi = true
      cfi_cross_dso = true
      debug = false
    }

    install_enable = true
    part_name = "input"
    subsystem_name = "multimodalinput"
  }
}

mmi_systemtest_executable("multi_group_binding_real_service_test") {
  sources = [ "multi_group_binding_real_service_test.cpp" ]
}

mmi_systemtest_executable("multi_group_api_impact_test") {
  sources = [ "multi_group_api_impact_test.cpp" ]
}

mmi_systemtest_executable("mouse_api_hidumper_test") {
  sources = [ "mouse_api_hidumper_test.cpp" ]
}

mmi_systemtest_executable("mouse_visual_movement_test") {
  sources = [ "mouse_visual_movement_test.cpp" ]
}

group("multi_group_system_tests") {
  deps = [
    ":multi_group_binding_real_service_test",
    ":multi_group_api_impact_test",
    ":mouse_api_hidumper_test",
    ":mouse_visual_movement_test",
  ]
}
